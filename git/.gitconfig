[alias]
  a = add -u
  aa = add
  b = fetch
  br = branch
  c = commit
  cc = commit -m '.'
  cm = commit -m
  co = checkout
  cp = clone
  d = diff
  dh = diff HEAD^..HEAD
  dm = diff main
  do = diff HEAD..origin/dev
  ds = diff --staged
  f = fetch
  h = help
  l = log
  l1 = log --pretty=oneline
  p = push
  rb = rebase
  rbm = rebase master
  rs = restore
  s = status -uno
  ss = status
  st = stash
  sta = stash apply
  stl = stash list
  wt = worktree
[init]
  defaultBranch = main
[user]
;   email = rmnull@users.noreply.github.com
;   name = rmnull
  useConfigOnly = true
[credential]
  helper = cache
[gpg]
  program = gpg2
[commit]
  gpgsign = false
[core]
  excludesfile = /home/rmnull/.gitignore
  pager = delta
 [interactive]
   diffFilter = delta --color-only
 [delta]
   navigate = true
   light = false
[merge]
  conflictstyle = diff3
[diff]
  algorithm = histogram
  colorMoved = default
[pull]
  ff = only
[rebase]
  autoStash = true
[merge]
  autoStash = true

[includeIf "gitdir:~/work/"]
  path = ~/work/.gitconfig

[includeIf "gitdir:~/lab/"]
  path = ~/lab/.gitconfig
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
